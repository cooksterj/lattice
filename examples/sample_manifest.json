    "model.jaffle_shop.order_payments": {
      "raw_sql": "{% set payment_methods = ['credit_card', 'coupon', 'bank_transfer', 'gift_card'] %}\n\nwith payments as (\n    select * from {{ ref('stg_payments') }}\n),\norders as (\n    select * from {{ ref('stg_orders') }}\n),\nfinal as (\n    select\n        orders.order_id,\n        {% for payment_method in payment_methods -%}\n        sum(case when payments.payment_method = '{{ payment_method }}' then payments.amount else 0 end) as {{ payment_method }}_amount\n        {%- if not loop.last %},{% endif -%}\n        {% endfor %}\n    from payments\n    left join orders using (order_id)\n    group by 1\n)\nselect * from final",
      "compiled": true,
      "database": "analytics",
      "schema": "public",
